{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build STM32 Debug",
            "type": "shell",
            "command": "make",
            "args": [
                "-j8",
                "all"
            ],
            "options": {
                "cwd": "${workspaceFolder}/Debug"
            },
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "Clean STM32 Debug",
            "type": "shell",
            "command": "make",
            "args": [
                "clean"
            ],
            "options": {
                "cwd": "${workspaceFolder}/Debug"
            }
        }
    ]
}
